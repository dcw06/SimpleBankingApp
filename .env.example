# SimpleBankingApp Environment Configuration
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env file or share credentials publicly

# Google OAuth Credentials (get from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Plaid Credentials (get from https://dashboard.plaid.com)
# Use 'sandbox' for testing, 'production' for live banking
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENV=sandbox

# Optional: WeChat integration (when set up)
WECHAT_APP_ID=optional_wechat_app_id
WECHAT_APP_SECRET=optional_wechat_app_secret
